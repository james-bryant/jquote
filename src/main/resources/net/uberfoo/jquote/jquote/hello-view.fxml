<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_LEFT" spacing="12.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="net.uberfoo.jquote.jquote.HelloController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
    </padding>

    <Label text="Schwab Quote" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <TextField fx:id="symbolInput" promptText="Enter symbol (e.g., AAPL)" onAction="#onSymbolEntered"/>
    <Label fx:id="statusLabel" wrapText="true"/>
    <Label fx:id="quoteLabel" wrapText="true" style="-fx-font-size: 14px;"/>
</VBox>
